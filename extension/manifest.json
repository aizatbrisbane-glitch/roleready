{
  "manifest_version": 3,
  "name": "AI Job Search Assistant",
  "version": "0.1.0",
  "description": "Send the visible job ad to your local AI Job Search Assistant.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:3004/*", "https://*.seek.com.au/*", "https://*.linkedin.com/*", "https://*.adzuna.com.au/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send job to assistant"
  }
}
